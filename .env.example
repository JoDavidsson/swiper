# Flutter (build-time or runtime)
# API_BASE_URL=https://europe-west1-<project>.cloudfunctions.net/api

# Firebase Functions
# ADMIN_PASSWORD=your-admin-password
# SUPPLY_ENGINE_URL=https://supply-engine-xxx.run.app

# Supply Engine
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# FIRESTORE_EMULATOR_HOST=localhost:8180
# SOURCES_JSON=/path/to/config/sources.json
# SUPPLY_ENGINE_URL=http://localhost:8081
# USER_AGENT=SwiperBot/0.1 (contact: johannes@branchandleaf.se)
# ENABLE_LLM_EXTRACTOR=false
# LLM_API_KEY=

# Recommendation engine rollout profile (conservative)
# DECK_ITEMS_FETCH_LIMIT=700
# DECK_CANDIDATE_CAP=400
# DECK_RANK_WINDOW_MULTIPLIER=48
# RANKER_EXPLORATION_RATE=0
# RANKER_ENABLE_MMR_RERANK=false
# DECK_RETRIEVAL_DOCS_CACHE_TTL_MS=15000
