rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Items: public read (deck); writes only via Admin SDK (Supply Engine / Functions).
    match /items/{itemId} {
      allow read: if true;
      allow write: if false;
    }
    // Sources: read for admin; writes only via Admin SDK.
    match /sources/{sourceId} {
      allow read: if true;
      allow write: if false;
    }
    // Anonymous sessions: client reads/writes by sessionId (opaque).
    match /anonSessions/{sessionId} {
      allow read, write: if true;
      match /likes/{itemId} {
        allow read, write: if true;
      }
      match /preferenceWeights/{docId} {
        allow read, write: if true;
      }
    }
    match /swipes/{swipeId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
    match /likes/{likeId} {
      allow read, write: if true;
    }
    match /shortlists/{shortlistId} {
      allow read, write: if true;
    }
    match /shortlists/{shortlistId}/items/{itemId} {
      allow read, write: if true;
    }
    match /events/{eventId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    // Admin allowlist: only Functions (Admin SDK) can read; used to check Firebase Auth admin access.
    match /adminAllowlist/{email} {
      allow read, write: if false;
    }
    // Ingestion: read for admin; writes only via Admin SDK (Supply Engine).
    match /ingestionRuns/{runId} {
      allow read: if true;
      allow write: if false;
    }
    match /ingestionJobs/{jobId} {
      allow read: if true;
      allow write: if false;
    }
    // Curated onboarding sofas: public read; writes only via Admin SDK.
    match /curatedOnboardingSofas/{itemId} {
      allow read: if true;
      allow write: if false;
    }
    // Onboarding picks: reads via API; writes only via Admin SDK (Functions).
    match /onboardingPicks/{sessionId} {
      allow read: if true;
      allow write: if false;
    }
    // Onboarding v2 profiles: reads via API; writes only via Admin SDK (Functions).
    match /onboardingProfiles/{sessionId} {
      allow read: if true;
      allow write: if false;
    }
    // Sessions: public read; writes only via Admin SDK (Functions).
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if false;
    }
    // Persona signals for collaborative filtering: public read; writes only via Admin SDK.
    match /personaSignals/{signalId} {
      allow read: if true;
      allow write: if false;
    }

    // Users: authenticated users can read own; writes only via Admin SDK (Functions).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Decision Rooms: public read; writes only via Admin SDK (Functions).
    match /decisionRooms/{roomId} {
      allow read: if true;
      allow write: if false;
      
      // Items within a decision room
      match /items/{itemId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // Votes: public read (to see vote counts); writes only via Admin SDK (Functions).
    match /votes/{voteId} {
      allow read: if true;
      allow write: if false;
    }

    // Comments: public read; writes only via Admin SDK (Functions).
    match /comments/{commentId} {
      allow read: if true;
      allow write: if false;
    }

    // Retailers: public read for basic info; writes only via Admin SDK (Functions).
    match /retailers/{retailerId} {
      allow read: if true;
      allow write: if false;
    }

    // Segments: public read for templates; writes only via Admin SDK (Functions).
    match /segments/{segmentId} {
      allow read: if true;
      allow write: if false;
    }

    // Campaigns: authenticated retailer owners read; writes only via Admin SDK (Functions).
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Scores: authenticated users read; writes only via Admin SDK (Functions).
    match /scores/{scoreId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Score calculation logs: admin only (handled by Admin SDK).
    match /scoreCalculationLogs/{logId} {
      allow read, write: if false;
    }

    // Score recalculation jobs: admin only (handled by Admin SDK).
    match /scoreRecalculationJobs/{jobId} {
      allow read, write: if false;
    }
  }
}
